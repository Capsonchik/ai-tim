PORT=3001
#
# Base URL of your Jira, e.g. https://jira.company.local
JIRA_BASE_URL=https://jira.example.local
#
# For /api/login redirect destination (optional; if empty, uses request origin)
APP_BASE_URL=http://localhost:5173
#
# Enable CORS for local dev (comma-separated). Example: http://localhost:5173
# Note: cookie-based Jira auth usually requires serving the app under the same site as Jira.
CORS_ORIGINS=http://localhost:5173
